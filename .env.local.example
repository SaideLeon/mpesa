# ─── M-Pesa Mozambique ────────────────────────────────────────────────────────
# Obtém estas credenciais em: https://developer.mpesa.vm.co.mz
# 1. Cria uma conta no portal
# 2. Cria uma nova aplicação
# 3. Copia as credenciais abaixo

# A tua API Key (gerada no portal do developer)
MPESA_API_KEY=

# A chave pública da Vodacom MZ (disponível no portal)
MPESA_PUBLIC_

# Código do teu negócio/serviço no M-Pesa (atribuído pela Vodacom)
MPESA_SERVICE_PROVIDER_CODE=171717

# O domínio da tua aplicação (usado nos headers de origem)
# Em desenvolvimento: developer.mpesa.vm.co.mz
# Em produção: o teu domínio (ex: meusite.co.mz)
MPESA_ORIGIN=developer.mpesa.vm.co.mz

# Ambiente: "sandbox" para testes, "production" para produção
MPESA_ENVIRONMENT=sandbox

# ─── URL do Webhook ───────────────────────────────────────────────────────────
# Para desenvolvimento local, usa ngrok:
#   npx ngrok http 3000
# Depois regista este URL no portal M-Pesa como "Callback URL":
#   https://xxxx.ngrok.io/api/payments/mpesa/webhook
MPESA_WEBHOOK_URL=https://o-teu-dominio.co.mz/api/payments/mpesa/webhook
